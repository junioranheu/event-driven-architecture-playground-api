{
  "Logging": {
    "LogLevel": {
      // Nível global de logs para toda a aplicação;
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "*" ]
  },
  "AllowedHosts": "*",
  "OutboxPublisher": {
    "PollingIntervalSeconds": 5,
    "BatchSize": 20,
    "MaxRetryDelaySeconds": 300
  }
}